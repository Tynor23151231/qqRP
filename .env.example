BOT_TOKEN=123456:your-telegram-bot-token
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/qqrp_bot
COMMAND_PREFIX=.

# Telegram ID администраторов через запятую — им доступна встроенная
# админ-консоль /admin (выдача/отзыв премиума). Свой ID можно узнать у @userinfobot.
ADMIN_IDS=

# Стоимость и длительность премиум-подписки (Telegram Stars)
PREMIUM_PRICE_STARS=99
PREMIUM_DURATION_DAYS=30

DEFAULT_LANGUAGE=ru
LOG_LEVEL=INFO
